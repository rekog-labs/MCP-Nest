{
  "name": "mcp-nest-workspace",
  "version": "2.0.0-alpha.0",
  "description": "Workspace root for @rekog/mcp-nest and @rekog/mcp-nest-auth",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rekog-labs/MCP-Nest"
  },
  "scripts": {
    "build": "bun run --filter '@rekog/mcp-nest' build && bun run --filter '@rekog/mcp-nest-auth' build",
    "prepare": "npm run build",
    "test": "bun test $(find \"$PWD/tests\" \"$PWD/packages\" -name '*.spec.ts')",
    "test:watch": "bun test $(find \"$PWD/tests\" \"$PWD/packages\" -name '*.spec.ts') --watch",
    "lint": "eslint \"{packages,apps,libs,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"packages/**/*.ts\" \"tests/**/*.ts\"",
    "examples:local": "bash scripts/use-examples.sh local",
    "examples:published": "bash scripts/use-examples.sh published",
    "e2e": "cd e2e && bun install && bun test",
    "e2e:local": "bash scripts/use-examples.sh local && npm run build && npm run e2e",
    "e2e:published": "bash scripts/use-examples.sh published next && npm run e2e"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/testing": "^11.1.14",
    "@nestjs/typeorm": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.7",
    "@types/passport-github": "^1.1.13",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-azure-ad-oauth2": "^0.0.4",
    "passport-github": "^1.1.0",
    "passport-google-oauth20": "^2.0.0",
    "path-to-regexp": "^8.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^1.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "zod": "^4.3.5"
  },
  "overrides": {
    "qs": "^6.14.1",
    "body-parser": "^2.2.1",
    "jws": "^3.2.3",
    "hono": "^4.11.4"
  }
}
